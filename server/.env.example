# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=8h

# Database
# DB_DIALECT can be "sqlite" (zero-config, default for local/dev) or "postgres"
DB_DIALECT=sqlite

# Used only when DB_DIALECT=sqlite
SQLITE_STORAGE=./data/database.sqlite

# Used only when DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=expense_voucher_db
DB_USER=postgres
DB_PASSWORD=postgres

# Frontend origin (for CORS)
CLIENT_URL=http://localhost:5173
